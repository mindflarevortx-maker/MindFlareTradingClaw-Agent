{
  "manifest_version": 3,
  "name": "MindFlare TradingClaw Agent",
  "version": "1.4.0",
  "description": "AI-powered trading assistant for market-qx.trade — WebSocket sniffing, technical analysis, LLM signals, auto-pilot trading with martingale, backtesting, and self-improvement.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms",
    "offscreen",
    "scripting",
    "webRequest",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://market-qx.trade/*",
    "https://*.market-qx.trade/*"
  ],
  "background": {
    "service_worker": "bg/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://market-qx.trade/*"],
      "js": [
        "core.js",
        "candle-store.js",
        "historical-loader.js",
        "technical-engine.js",
        "strategy-engine.js",
        "dom-claw.js",
        "scanner.js",
        "llm-claw.js",
        "self-improvement.js",
        "agent.js",
        "chat.js",
        "ui-overlay.js",
        "bootstrap.js"
      ],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://market-qx.trade/*"],
      "js": ["inject-page-hook.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js", "icons/*", "prompts/*"],
      "matches": ["https://market-qx.trade/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
